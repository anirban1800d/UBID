<?xml version="1.0" encoding="utf-8"?>
<!--
  ╔══════════════════════════════════════════════════════════════════╗
  ║  BGIE App · item_match_row.xml                                   ║
  ║  Reusable row used 3× inside matchExplainCard                    ║
  ╠══════════════════════════════════════════════════════════════════╣
  ║  Bind in fragment after inflate:                                 ║
  ║                                                                  ║
  ║   val row = rowNameSimilarity                                    ║
  ║   row.findViewById<TextView>(R.id.tvMatchKey).text =            ║
  ║       getString(R.string.detail_name_similarity)                 ║
  ║   row.findViewById<TextView>(R.id.tvMatchValue).text = "87%"    ║
  ║   row.findViewById<View>(R.id.pctBarFill)                       ║
  ║       .updateLayoutParams { width = dpToPx(87 * 56 / 100) }    ║
  ║                                                                  ║
  ║  For PAN match (YES / NO):                                       ║
  ║   row.findViewById<View>(R.id.pctBarWrap).isVisible = false     ║
  ║   row.findViewById<TextView>(R.id.tvMatchValue)                 ║
  ║       .setTextColor(getColor(R.color.tag_green_text))            ║
  ╚══════════════════════════════════════════════════════════════════╝
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <!-- Key label  e.g. "Name similarity" -->
    <TextView
        android:id="@+id/tvMatchKey"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textColor="@color/text_muted"
        android:textSize="11sp"
        tools:text="Name similarity" />

    <!-- Percentage bar track  (56 dp wide × 3 dp tall)
         Set GONE for YES/NO rows (PAN match) -->
    <FrameLayout
        android:id="@+id/pctBarWrap"
        android:layout_width="56dp"
        android:layout_height="3dp"
        android:layout_marginEnd="6dp"
        android:background="@drawable/bg_pct_track">

        <!--
          pctBarFill width set programmatically:
            fill.updateLayoutParams { width = dpToPx(value * 56 / 100) }
        -->
        <View
            android:id="@+id/pctBarFill"
            android:layout_width="0dp"
            android:layout_height="3dp"
            android:background="@drawable/bg_pct_fill"
            tools:layout_width="49dp" />

    </FrameLayout>

    <!-- Value  e.g. "87%"  or  "YES" -->
    <TextView
        android:id="@+id/tvMatchValue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/text_secondary"
        android:textSize="11sp"
        android:textStyle="bold"
        tools:text="87%" />

</LinearLayout>
