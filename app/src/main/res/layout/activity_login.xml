<?xml version="1.0" encoding="utf-8"?>
<!--
  ╔══════════════════════════════════════════════════════════════╗
  ║  BGIE · Screen 01 · Sign In                                  ║
  ║  activity_login.xml                                          ║
  ╚══════════════════════════════════════════════════════════════╝

  Layout hierarchy:
  ScrollView  (bg_screen)
  └── LinearLayout  (vertical, screen_padding)
      ├── View  accent strip  (2dp, bg_accent_strip)
      ├── FrameLayout  logo ring  (64×64)
      │   └── FrameLayout  logo card  (48×48, bg_logo_card)
      │       └── ImageView  ic_logo_grid
      ├── TextView  "UBID"
      ├── TextView  "Business Graph Intelligence"
      ├── View  divider  (1dp, bg_divider)
      ├── TextView  label "OFFICER ID / EMAIL"
      ├── LinearLayout  email field  (bg_input_field)
      │   ├── ImageView  ic_email
      │   └── EditText
      ├── TextView  label "PASSPHRASE"
      ├── LinearLayout  passphrase field  (bg_input_field)
      │   ├── LinearLayout  left group
      │   │   ├── ImageView  ic_lock
      │   │   └── EditText  (inputType=textPassword)
      │   └── ImageView  ic_eye  (toggle)
      ├── Button  "Sign in →"
      ├── TextView  "Forgot credentials?"
      ├── LinearLayout  OR row
      │   ├── View  line
      │   ├── TextView  "OR"
      │   └── View  line
      ├── Button  "Create new account"  (outline)
      └── LinearLayout  sign-up note
          ├── TextView  "New officer? "
          └── TextView  "Sign up →"  (clickable)
-->

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_screen"
    android:fillViewport="true"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        tools:context=".LoginActivity">

        <!-- ── Accent gradient strip ── -->
        <View
            android:id="@+id/view_accent_strip"
            android:layout_width="match_parent"
            android:layout_height="@dimen/accent_strip_height"
            android:background="@drawable/bg_accent_strip" />

        <!-- ── Content wrapper centred vertically ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingStart="@dimen/screen_padding_horizontal"
            android:paddingEnd="@dimen/screen_padding_horizontal"
            android:paddingTop="@dimen/screen_padding_top"
            android:paddingBottom="@dimen/screen_padding_bottom">

            <!-- ── Logo ring ── -->
            <FrameLayout
                android:id="@+id/fl_logo_ring"
                android:layout_width="@dimen/logo_ring_size"
                android:layout_height="@dimen/logo_ring_size"
                android:background="@drawable/bg_logo_ring"
                android:layout_marginBottom="@dimen/logo_bottom_margin">

                <!-- Logo card centred inside ring -->
                <FrameLayout
                    android:id="@+id/fl_logo_card"
                    android:layout_width="@dimen/logo_card_size"
                    android:layout_height="@dimen/logo_card_size"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_logo_card">

                    <!-- 4-square UBID icon -->
                    <ImageView
                        android:id="@+id/iv_logo"
                        android:layout_width="@dimen/logo_icon_size"
                        android:layout_height="@dimen/logo_icon_size"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_logo_grid"
                        android:contentDescription="@string/cd_logo" />

                </FrameLayout>
            </FrameLayout>

            <!-- ── App name "UBID" ── -->
            <TextView
                android:id="@+id/tv_app_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_logo_label"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_app_name"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:fontFamily="monospace"
                android:layout_marginBottom="4dp" />

            <!-- ── Tagline ── -->
            <TextView
                android:id="@+id/tv_tagline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_tagline"
                android:textColor="@color/text_label"
                android:textSize="@dimen/text_tagline"
                android:letterSpacing="0.18"
                android:textAllCaps="true"
                android:layout_marginBottom="@dimen/tagline_bottom_margin" />

            <!-- ── Divider ── -->
            <View
                android:id="@+id/view_divider"
                android:layout_width="match_parent"
                android:layout_height="@dimen/divider_height"
                android:background="@drawable/bg_divider"
                android:layout_marginBottom="@dimen/divider_margin_bottom" />

            <!-- ── Label: Officer ID / Email ── -->
            <TextView
                android:id="@+id/tv_label_email"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/label_officer_id"
                android:textColor="@color/text_label"
                android:textSize="@dimen/text_label"
                android:textStyle="bold"
                android:letterSpacing="0.10"
                android:textAllCaps="true"
                android:layout_marginBottom="@dimen/label_bottom_margin" />

            <!-- ── Email input field ── -->
            <LinearLayout
                android:id="@+id/ll_field_email"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/selector_input_field"
                android:paddingStart="@dimen/field_padding_horizontal"
                android:paddingEnd="@dimen/field_padding_horizontal"
                android:paddingTop="@dimen/field_padding_vertical"
                android:paddingBottom="@dimen/field_padding_vertical"
                android:layout_marginBottom="@dimen/field_bottom_margin">

                <ImageView
                    android:id="@+id/iv_icon_email"
                    android:layout_width="@dimen/field_icon_size"
                    android:layout_height="@dimen/field_icon_size"
                    android:src="@drawable/ic_email"
                    android:contentDescription="@string/cd_email_icon"
                    android:layout_marginEnd="@dimen/field_icon_margin" />

                <EditText
                    android:id="@+id/et_email"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@null"
                    android:hint="@string/hint_officer_id"
                    android:textColor="@color/text_field_value"
                    android:textColorHint="@color/text_label"
                    android:textSize="@dimen/text_field"
                    android:inputType="textEmailAddress"
                    android:imeOptions="actionNext"
                    android:maxLines="1"
                    android:singleLine="true"
                    android:cursorVisible="true" />

            </LinearLayout>

            <!-- ── Label: Passphrase ── -->
            <TextView
                android:id="@+id/tv_label_pass"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/label_passphrase"
                android:textColor="@color/text_label"
                android:textSize="@dimen/text_label"
                android:textStyle="bold"
                android:letterSpacing="0.10"
                android:textAllCaps="true"
                android:layout_marginBottom="@dimen/label_bottom_margin" />

            <!-- ── Passphrase input field ── -->
            <LinearLayout
                android:id="@+id/ll_field_pass"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/selector_input_field"
                android:paddingStart="@dimen/field_padding_horizontal"
                android:paddingEnd="@dimen/field_padding_horizontal"
                android:paddingTop="@dimen/field_padding_vertical"
                android:paddingBottom="@dimen/field_padding_vertical"
                android:layout_marginBottom="@dimen/field_bottom_margin">

                <!-- Left: lock icon + password edit text -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:id="@+id/iv_icon_lock"
                        android:layout_width="@dimen/field_icon_size"
                        android:layout_height="@dimen/field_icon_size"
                        android:src="@drawable/ic_lock"
                        android:contentDescription="@string/cd_lock_icon"
                        android:layout_marginEnd="@dimen/field_icon_margin" />

                    <EditText
                        android:id="@+id/et_password"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@null"
                        android:hint="@string/hint_passphrase"
                        android:textColor="@color/text_field_value"
                        android:textColorHint="@color/text_label"
                        android:textSize="@dimen/text_field"
                        android:inputType="textPassword"
                        android:imeOptions="actionDone"
                        android:maxLines="1"
                        android:singleLine="true" />

                </LinearLayout>

                <!-- Right: eye toggle icon -->
                <ImageView
                    android:id="@+id/iv_toggle_pass"
                    android:layout_width="@dimen/field_icon_size"
                    android:layout_height="@dimen/field_icon_size"
                    android:src="@drawable/ic_eye"
                    android:contentDescription="@string/cd_eye_icon"
                    android:layout_marginStart="8dp"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

            <!-- ── Sign In button ── -->
            <Button
                android:id="@+id/btn_sign_in"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/btn_sign_in"
                android:textColor="@color/text_btn_primary"
                android:textSize="@dimen/text_btn"
                android:textStyle="bold"
                android:letterSpacing="0.06"
                android:background="@drawable/selector_btn_signin"
                android:paddingTop="@dimen/btn_padding_vertical"
                android:paddingBottom="@dimen/btn_padding_vertical"
                android:stateListAnimator="@null"
                android:layout_marginBottom="@dimen/btn_bottom_margin" />

            <!-- ── Forgot credentials ── -->
            <TextView
                android:id="@+id/tv_forgot"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/link_forgot"
                android:textColor="@color/text_forgot"
                android:textSize="@dimen/text_forgot"
                android:layout_marginBottom="14dp"
                android:clickable="true"
                android:focusable="true" />

            <!-- ── OR divider row ── -->
            <LinearLayout
                android:id="@+id/ll_or_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <View
                    android:layout_width="0dp"
                    android:layout_height="@dimen/or_line_height"
                    android:layout_weight="1"
                    android:background="@color/border_card" />

                <TextView
                    android:id="@+id/tv_or"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/text_or"
                    android:textColor="@color/text_label"
                    android:textSize="@dimen/text_or"
                    android:letterSpacing="0.08"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="@dimen/or_line_height"
                    android:layout_weight="1"
                    android:background="@color/border_card" />

            </LinearLayout>

            <!-- ── Create account outline button ── -->
            <Button
                android:id="@+id/btn_create_account"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/btn_create_account"
                android:textColor="@color/brand_blue_muted"
                android:textSize="@dimen/text_btn"
                android:textStyle="bold"
                android:letterSpacing="0.06"
                android:background="@drawable/bg_btn_outline"
                android:paddingTop="@dimen/btn_padding_vertical"
                android:paddingBottom="@dimen/btn_padding_vertical"
                android:stateListAnimator="@null"
                android:layout_marginBottom="10dp" />

            <!-- ── Sign up note ── -->
            <LinearLayout
                android:id="@+id/ll_signup_note"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/tv_new_officer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/text_new_officer"
                    android:textColor="@color/text_forgot"
                    android:textSize="@dimen/text_signup_note" />

                <TextView
                    android:id="@+id/tv_sign_up_link"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/link_sign_up"
                    android:textColor="@color/text_signup_link"
                    android:textSize="@dimen/text_signup_note"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

        </LinearLayout>

        <!-- ── Footer ── -->
        <LinearLayout
            android:id="@+id/ll_footer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@color/bg_surface"
            android:paddingTop="6dp"
            android:paddingBottom="10dp">

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/border_footer"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/tv_footer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/footer_auth"
                android:textColor="@color/text_footer"
                android:textSize="@dimen/text_footer"
                android:letterSpacing="0.04" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
