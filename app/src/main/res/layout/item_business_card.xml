<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="7dp"
    android:background="@drawable/bg_business_card_pressed"
    android:clickable="true"
    android:focusable="true"
    android:orientation="vertical"
    android:padding="12dp">

    <!-- Row 1: Business name + risk score badge -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="3dp">

        <TextView
            android:id="@+id/tv_biz_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="#D0E4F5"
            android:textSize="12sp"
            android:textStyle="bold"
            tools:text="Ramesh Steel Works" />

        <TextView
            android:id="@+id/tv_risk_score"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_tag_score_amber"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#F9A825"
            tools:text="72" />

    </LinearLayout>

    <!-- Row 2: UBID in monospace -->
    <TextView
        android:id="@+id/tv_ubid"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="2dp"
        android:fontFamily="monospace"
        android:textColor="#2E5A82"
        android:textSize="10sp"
        tools:text="IN-MH-PUNE-2024-00831" />

    <!-- Row 3: records · location · status -->
    <TextView
        android:id="@+id/tv_meta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#2E5A82"
        android:textSize="10sp"
        tools:text="5 records · Bhosari MIDC, Pune · Dormant" />

</LinearLayout>
