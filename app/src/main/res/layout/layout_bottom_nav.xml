<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/bottom_nav"
    android:layout_width="match_parent"
    android:layout_height="60dp"
    android:orientation="horizontal"
    android:background="#0d1926"
    android:paddingTop="8dp"
    android:gravity="center_vertical">

    <LinearLayout
        android:id="@+id/nav_home"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true">
        <ImageView
            android:id="@+id/iv_nav_home"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_nav_home" />
        <TextView
            android:id="@+id/tv_nav_home"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Home"
            android:textSize="10sp"
            android:textColor="#4d6a85" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/nav_list"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true">
        <ImageView
            android:id="@+id/iv_nav_list"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_nav_list" />
        <TextView
            android:id="@+id/tv_nav_list"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="List"
            android:textSize="10sp"
            android:textColor="#4d6a85" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/nav_graph"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true">
        <ImageView
            android:id="@+id/iv_nav_graph"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_nav_graph" />
        <TextView
            android:id="@+id/tv_nav_graph"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Graph"
            android:textSize="10sp"
            android:textColor="#4d6a85" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/nav_search"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:clickable="true"
        android:focusable="true">
        <ImageView
            android:id="@+id/iv_nav_search"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_nav_search" />
        <TextView
            android:id="@+id/tv_nav_search"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Search"
            android:textSize="10sp"
            android:textColor="#4d6a85" />
    </LinearLayout>
</LinearLayout>