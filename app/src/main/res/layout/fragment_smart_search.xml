<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_screen">

    <View
        android:id="@+id/accentStrip"
        android:layout_width="0dp"
        android:layout_height="2dp"
        android:background="@drawable/gradient_accent_strip"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:background="@color/bg_surface_dark"
        android:paddingStart="16dp"
        android:paddingEnd="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/accentStrip">

        <TextView
            android:id="@+id/tvToolbarTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:letterSpacing="0.02"
            android:text="@string/search_toolbar_title"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <LinearLayout
        android:id="@+id/searchInputBox"
        android:layout_width="0dp"
        android:layout_height="40dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_search_box"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <ImageView
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_marginEnd="8dp"
            android:contentDescription="@string/content_desc_search"
            android:src="@drawable/ic_search"
            app:tint="@color/search_icon" />

        <EditText
            android:id="@+id/etNlpQuery"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@null"
            android:hint="@string/search_nlp_hint"
            android:imeOptions="actionSearch"
            android:inputType="text"
            android:maxLines="1"
            android:textColor="@color/text_subtle"
            android:textColorHint="@color/text_placeholder"
            android:textSize="12sp"
            android:textStyle="italic" />

        <ImageView
            android:id="@+id/btnVoiceInput"
            android:layout_width="wrap_content"
            android:layout_height="20dp"
            android:layout_marginStart="8dp"
            android:contentDescription="@string/content_desc_voice_search"
            android:src="@drawable/ic_mic"
            app:tint="@color/accent_blue_bright" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/filterInputContainer"
        android:layout_width="0dp"
        android:layout_height="40dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="10dp"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/searchInputBox">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:background="@drawable/bg_search_box"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="4dp">

            <Spinner
                android:id="@+id/spinnerCategory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@null"
                android:overlapAnchor="false"
                android:popupBackground="@color/bg_surface_dark" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_search_box"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="4dp">

            <Spinner
                android:id="@+id/spinnerRegion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@null"
                android:overlapAnchor="false"
                android:popupBackground="@color/bg_surface_dark" />
        </LinearLayout>
    </LinearLayout>

    <HorizontalScrollView
        android:id="@+id/tokenScrollView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="8dp"
        android:scrollbars="none"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/filterInputContainer"
        tools:visibility="visible">

        <LinearLayout
            android:id="@+id/tokenChipGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_chip_blue_active"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:text="Steel · Pune"
                android:textColor="@color/tag_blue_text"
                android:textSize="11sp"
                tools:ignore="HardcodedText" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_chip_blue_active"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:text="Risk &gt; 60"
                android:textColor="@color/tag_blue_text"
                android:textSize="11sp"
                tools:ignore="HardcodedText" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chip_amber"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:text="No inspection 12mo"
                android:textColor="@color/tag_amber_text"
                android:textSize="11sp"
                tools:ignore="HardcodedText" />
        </LinearLayout>
    </HorizontalScrollView>

    <TextView
        android:id="@+id/tvResultCount"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="8dp"
        android:letterSpacing="0.06"
        android:textAllCaps="true"
        android:textColor="@color/text_dim"
        android:textSize="11sp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tokenScrollView"
        tools:text="3 results found"
        tools:visibility="visible" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvSearchResults"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="6dp"
        android:clipToPadding="false"
        android:paddingBottom="12dp"
        android:scrollbars="none"
        android:visibility="gone"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        app:layout_constraintBottom_toTopOf="@id/aiParsedCard"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvResultCount"
        tools:listitem="@layout/item_business_card"
        tools:visibility="visible" />

    <androidx.cardview.widget.CardView
        android:id="@+id/aiParsedCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="8dp"
        android:visibility="gone"
        app:cardBackgroundColor="@color/bg_card"
        app:cardCornerRadius="8dp"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toTopOf="@id/bottom_nav"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        tools:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_explain_card"
            android:orientation="vertical"
            android:padding="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:letterSpacing="0.06"
                android:text="@string/search_ai_parsed_title"
                android:textAllCaps="true"
                android:textColor="@color/text_dim"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/tvParsedTypeCity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="2dp"
                android:textColor="@color/text_subtle"
                android:textSize="11sp"
                tools:text="Type: Steel · City: Pune" />

            <TextView
                android:id="@+id/tvParsedInspection"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="2dp"
                android:textColor="@color/text_subtle"
                android:textSize="11sp"
                tools:text="No inspection &gt; 12 months" />

            <TextView
                android:id="@+id/tvParsedRisk"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_subtle"
                android:textSize="11sp"
                tools:text="Risk threshold: &gt; 60" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:id="@+id/bottom_nav"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:background="@color/bg_surface_dark"
        android:paddingTop="8dp"
        android:gravity="center_vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:id="@+id/nav_home"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/iv_nav_home"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_nav_home"
                android:contentDescription="@string/nav_cd_home" />

            <TextView
                android:id="@+id/tv_nav_home"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nav_home"
                android:textSize="10sp"
                android:textColor="@color/nav_inactive" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_list"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/iv_nav_list"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_nav_list"
                android:contentDescription="@string/nav_cd_list" />

            <TextView
                android:id="@+id/tv_nav_list"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nav_list"
                android:textSize="10sp"
                android:textColor="@color/nav_inactive" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_graph"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/iv_nav_graph"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_nav_graph"
                android:contentDescription="@string/nav_cd_graph" />

            <TextView
                android:id="@+id/tv_nav_graph"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nav_graph"
                android:textSize="10sp"
                android:textColor="@color/nav_inactive" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_search"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/iv_nav_search"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_nav_search_active"
                android:contentDescription="@string/nav_cd_search" />

            <TextView
                android:id="@+id/tv_nav_search"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nav_search"
                android:textSize="10sp"
                android:textColor="@color/nav_active" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>