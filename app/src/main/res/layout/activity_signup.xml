<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_screen"
    android:fillViewport="true"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- ── Accent strip ── -->
        <View
            android:id="@+id/view_accent_strip"
            android:layout_width="match_parent"
            android:layout_height="@dimen/accent_strip_height"
            android:background="@drawable/bg_accent_strip" />

        <!-- ── Content ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/screen_padding_horizontal"
            android:paddingEnd="@dimen/screen_padding_horizontal"
            android:paddingTop="16dp"
            android:paddingBottom="@dimen/screen_padding_bottom">

            <!-- ── Back row ── -->
            <LinearLayout
                android:id="@+id/ll_back"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="14dp">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_arrow_back"
                    android:contentDescription="@string/cd_back_arrow"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/link_back_sign_in"
                    android:textColor="@color/brand_blue_muted"
                    android:textSize="10sp" />

            </LinearLayout>

            <!-- ── Logo + Title row ── -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="6dp">

                <FrameLayout
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_logo_card"
                    android:layout_marginEnd="10dp">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_logo_grid"
                        android:contentDescription="@string/cd_logo" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/app_logo_label"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.10" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/title_create_account"
                        android:textColor="@color/text_label"
                        android:textSize="8sp"
                        android:textAllCaps="true"
                        android:letterSpacing="0.14" />
                </LinearLayout>

            </LinearLayout>

            <!-- ── Divider ── -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@drawable/bg_divider"
                android:layout_marginBottom="12dp"
                android:layout_marginTop="8dp" />

            <!-- ── Full Name ── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/label_full_name"
                android:textColor="@color/text_label"
                android:textSize="@dimen/text_label"
                android:textStyle="bold"
                android:letterSpacing="0.10"
                android:textAllCaps="true"
                android:layout_marginBottom="4dp" />

            <LinearLayout
                android:id="@+id/ll_field_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/selector_input_field"
                android:paddingStart="@dimen/field_padding_horizontal"
                android:paddingEnd="@dimen/field_padding_horizontal"
                android:paddingTop="@dimen/field_padding_vertical"
                android:paddingBottom="@dimen/field_padding_vertical"
                android:layout_marginBottom="@dimen/field_bottom_margin">

                <ImageView
                    android:layout_width="@dimen/field_icon_size"
                    android:layout_height="@dimen/field_icon_size"
                    android:src="@drawable/ic_person"
                    android:contentDescription="@string/cd_person_icon"
                    android:layout_marginEnd="@dimen/field_icon_margin" />

                <EditText
                    android:id="@+id/et_full_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@null"
                    android:hint="@string/hint_full_name"
                    android:textColor="@color/text_field_value"
                    android:textColorHint="@color/text_label"
                    android:textSize="@dimen/text_field"
                    android:inputType="textPersonName"
                    android:imeOptions="actionNext"
                    android:singleLine="true" />
            </LinearLayout>

            <!-- ── Department ── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/label_department"
                android:textColor="@color/text_label"
                android:textSize="@dimen/text_label"
                android:textStyle="bold"
                android:letterSpacing="0.10"
                android:textAllCaps="true"
                android:layout_marginBottom="4dp" />

            <LinearLayout
                android:id="@+id/ll_field_dept"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/selector_input_field"
                android:paddingStart="@dimen/field_padding_horizontal"
                android:paddingEnd="@dimen/field_padding_horizontal"
                android:paddingTop="@dimen/field_padding_vertical"
                android:paddingBottom="@dimen/field_padding_vertical"
                android:layout_marginBottom="@dimen/field_bottom_margin"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="@dimen/field_icon_size"
                    android:layout_height="@dimen/field_icon_size"
                    android:src="@drawable/ic_building"
                    android:contentDescription="@string/cd_building_icon"
                    android:layout_marginEnd="@dimen/field_icon_margin" />

                <TextView
                    android:id="@+id/tv_department"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/hint_department"
                    android:textColor="@color/text_label"
                    android:textSize="@dimen/text_field" />

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_chevron_down"
                    android:contentDescription="@string/cd_dropdown_icon" />
            </LinearLayout>

            <!-- ── Officer ID / Email ── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/label_officer_id"
                android:textColor="@color/text_label"
                android:textSize="@dimen/text_label"
                android:textStyle="bold"
                android:letterSpacing="0.10"
                android:textAllCaps="true"
                android:layout_marginBottom="4dp" />

            <LinearLayout
                android:id="@+id/ll_field_email_reg"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/selector_input_field"
                android:paddingStart="@dimen/field_padding_horizontal"
                android:paddingEnd="@dimen/field_padding_horizontal"
                android:paddingTop="@dimen/field_padding_vertical"
                android:paddingBottom="@dimen/field_padding_vertical"
                android:layout_marginBottom="@dimen/field_bottom_margin">

                <ImageView
                    android:layout_width="@dimen/field_icon_size"
                    android:layout_height="@dimen/field_icon_size"
                    android:src="@drawable/ic_email"
                    android:contentDescription="@string/cd_email_icon"
                    android:layout_marginEnd="@dimen/field_icon_margin" />

                <EditText
                    android:id="@+id/et_email_reg"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@null"
                    android:hint="@string/hint_officer_id"
                    android:textColor="@color/text_field_value"
                    android:textColorHint="@color/text_label"
                    android:textSize="@dimen/text_field"
                    android:inputType="textEmailAddress"
                    android:imeOptions="actionNext"
                    android:singleLine="true" />
            </LinearLayout>

            <!-- ── Set Passphrase ── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/label_set_passphrase"
                android:textColor="@color/text_label"
                android:textSize="@dimen/text_label"
                android:textStyle="bold"
                android:letterSpacing="0.10"
                android:textAllCaps="true"
                android:layout_marginBottom="4dp" />

            <LinearLayout
                android:id="@+id/ll_field_pass_reg"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/selector_input_field"
                android:paddingStart="@dimen/field_padding_horizontal"
                android:paddingEnd="@dimen/field_padding_horizontal"
                android:paddingTop="@dimen/field_padding_vertical"
                android:paddingBottom="@dimen/field_padding_vertical"
                android:layout_marginBottom="6dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="@dimen/field_icon_size"
                        android:layout_height="@dimen/field_icon_size"
                        android:src="@drawable/ic_lock"
                        android:contentDescription="@string/cd_lock_icon"
                        android:layout_marginEnd="@dimen/field_icon_margin" />

                    <EditText
                        android:id="@+id/et_pass_reg"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@null"
                        android:hint="@string/hint_passphrase"
                        android:textColor="@color/text_field_value"
                        android:textColorHint="@color/text_label"
                        android:textSize="@dimen/text_field"
                        android:inputType="textPassword"
                        android:imeOptions="actionDone"
                        android:singleLine="true" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/iv_toggle_pass_reg"
                    android:layout_width="@dimen/field_icon_size"
                    android:layout_height="@dimen/field_icon_size"
                    android:src="@drawable/ic_eye"
                    android:contentDescription="@string/cd_eye_icon"
                    android:layout_marginStart="8dp"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <!-- ── Password strength bar ── -->
            <LinearLayout
                android:id="@+id/ll_strength"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">

                <!-- 4 segment bars -->
                <View android:id="@+id/bar1"
                    android:layout_width="0dp" android:layout_height="3dp"
                    android:layout_weight="1"
                    android:background="#3FCF8E"
                    android:layout_marginEnd="3dp" />
                <View android:id="@+id/bar2"
                    android:layout_width="0dp" android:layout_height="3dp"
                    android:layout_weight="1"
                    android:background="#3FCF8E"
                    android:layout_marginEnd="3dp" />
                <View android:id="@+id/bar3"
                    android:layout_width="0dp" android:layout_height="3dp"
                    android:layout_weight="1"
                    android:background="#F9A825"
                    android:layout_marginEnd="3dp" />
                <View android:id="@+id/bar4"
                    android:layout_width="0dp" android:layout_height="3dp"
                    android:layout_weight="1"
                    android:background="@color/border_card"
                    android:layout_marginEnd="10dp" />

                <TextView
                    android:id="@+id/tv_strength_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/text_strength_medium"
                    android:textColor="#F9A825"
                    android:textSize="8sp" />
            </LinearLayout>

            <!-- ── Register button ── -->
            <Button
                android:id="@+id/btn_register"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/btn_register"
                android:textColor="@color/text_btn_primary"
                android:textSize="@dimen/text_btn"
                android:textStyle="bold"
                android:letterSpacing="0.06"
                android:background="@drawable/selector_btn_signin"
                android:paddingTop="@dimen/btn_padding_vertical"
                android:paddingBottom="@dimen/btn_padding_vertical"
                android:stateListAnimator="@null"
                android:layout_marginBottom="8dp" />

            <!-- ── Already registered note ── -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/text_already_registered"
                    android:textColor="@color/text_forgot"
                    android:textSize="@dimen/text_signup_note" />

                <TextView
                    android:id="@+id/tv_sign_in_link"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/link_sign_in_reverse"
                    android:textColor="@color/text_signup_link"
                    android:textSize="@dimen/text_signup_note"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <!-- ── Terms text ── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/text_terms"
                android:textColor="@color/text_footer"
                android:textSize="8sp"
                android:gravity="center"
                android:lineSpacingExtra="2dp"
                android:layout_marginBottom="8dp" />

        </LinearLayout>

        <!-- ── Footer ── -->
        <LinearLayout
            android:id="@+id/ll_footer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@color/bg_surface"
            android:paddingTop="6dp"
            android:paddingBottom="10dp">

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/border_footer"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/footer_auth"
                android:textColor="@color/text_footer"
                android:textSize="@dimen/text_footer"
                android:letterSpacing="0.04" />
        </LinearLayout>

    </LinearLayout>

</ScrollView>
