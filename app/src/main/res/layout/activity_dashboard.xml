<!--
      ╔══════════════════════════════════════════════════════════════════╗
      ║  BGIE · Dashboard · fragment_dashboard.xml                      ║
      ║  ONLY dimensions changed — zero structural changes              ║
      ╠══════════════════════════════════════════════════════════════════╣
      ║  Before → After                                                  ║
      ║  ─────────────────────────────────────────────────────────────  ║
      ║  Accent strip      @dimen    →  3dp                              ║
      ║  Toolbar height    @dimen    →  56dp                             ║
      ║  Toolbar padH      @dimen    →  20dp                             ║
      ║  Toolbar title     @dimen    →  20sp                             ║
      ║  Avatar btn        24×24     →  36×36dp                          ║
      ║  Avatar icon       12×12     →  18×18dp                          ║
      ║  Body padding      6dp       →  16dp                             ║
      ║  Stat grid gap     5dp       →  8dp                              ║
      ║  Stat card pad     8dp       →  14dp                             ║
      ║  Stat number       15sp      →  22sp                             ║
      ║  Stat number mb    1dp       →  4dp                              ║
      ║  Stat label        7sp       →  11sp                             ║
      ║  Grid mb           8dp       →  20dp                             ║
      ║  Section label     7.5sp     →  12sp                             ║
      ║  Section mb        6dp       →  12dp                             ║
      ║  Act card pad      8dp       →  14dp                             ║
      ║  Act card mb       5dp       →  10dp                             ║
      ║  Act name          9sp       →  14sp                             ║
      ║  Act tag pad H     5dp       →  8dp                              ║
      ║  Act tag pad V     2dp       →  4dp                              ║
      ║  Act tag text      7sp       →  11sp                             ║
      ║  Act meta mb       3dp       →  6dp                              ║
      ║  Act meta text     7.5sp     →  12sp                             ║
      ║  Bottom nav H      60dp      →  64dp                             ║
      ╚══════════════════════════════════════════════════════════════════╝
     -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:tools="http://schemas.android.com/tools" android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:background="@color/bg_screen" android:fitsSystemWindows="true">
    <!--  ══ 1. ACCENT STRIP ══  -->
    <View android:id="@+id/view_accent_strip" android:layout_width="match_parent" android:layout_height="3dp" android:background="@drawable/bg_accent_strip"/>
    <!--  ══ 2. TOOLBAR ══  -->
    <LinearLayout android:id="@+id/toolbar" android:layout_width="match_parent" android:layout_height="56dp" android:orientation="horizontal" android:gravity="center_vertical" android:paddingStart="20dp" android:paddingEnd="20dp" android:background="@color/bg_surface">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/dashboard_title" android:textColor="@color/text_toolbar" android:textSize="20sp" android:fontFamily="sans-serif-medium"/>
        <FrameLayout android:id="@+id/btn_profile_logout" android:layout_width="36dp" android:layout_height="36dp" android:clickable="true" android:focusable="true" android:background="@drawable/bg_avatar_btn">
            <ImageView android:layout_width="18dp" android:layout_height="18dp" android:layout_gravity="center" android:src="@drawable/ic_user" app:tint="@color/accent_blue_bright"/>
        </FrameLayout>
    </LinearLayout>
    <!--  ══ 3. BODY ══  -->
    <ScrollView android:id="@+id/main_scroll_content" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:fillViewport="true" android:scrollbars="none" android:clipToPadding="false" android:paddingBottom="16dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
            <!--  ════ STAT GRID (2×2) ════  -->
            <GridLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:columnCount="2" android:rowCount="2" android:layout_marginBottom="20dp">
                <!--  Businesses — blue  -->
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:layout_marginEnd="8dp" android:layout_marginBottom="8dp" android:background="@drawable/bg_stat_card" android:orientation="vertical" android:padding="14dp" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="39,758" android:textColor="@color/accent_blue_bright" android:textSize="22sp" android:textStyle="bold" android:layout_marginBottom="4dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/stat_businesses" android:textColor="@color/text_dim" android:textSize="11sp" android:textAllCaps="true" android:letterSpacing="0.06"/>
                </LinearLayout>
                <!--  Matched today — green  -->
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:layout_marginStart="8dp" android:layout_marginBottom="8dp" android:background="@drawable/bg_stat_card" android:orientation="vertical" android:padding="14dp" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="None" android:textColor="@color/tag_green_text" android:textSize="22sp" android:textStyle="bold" android:layout_marginBottom="4dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/stat_matched_today" android:textColor="@color/text_dim" android:textSize="11sp" android:textAllCaps="true" android:letterSpacing="0.06"/>
                </LinearLayout>
                <!--  High risk — amber  -->
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:layout_marginEnd="8dp" android:background="@drawable/bg_stat_card" android:orientation="vertical" android:padding="14dp" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Soon" android:textColor="@color/tag_amber_text" android:textSize="22sp" android:textStyle="bold" android:layout_marginBottom="4dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/stat_high_risk" android:textColor="@color/text_dim" android:textSize="11sp" android:textAllCaps="true" android:letterSpacing="0.06"/>
                </LinearLayout>
                <!--  Pending review — red  -->
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:layout_marginStart="8dp" android:background="@drawable/bg_stat_card" android:orientation="vertical" android:padding="14dp" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Soon" android:textColor="@color/tag_red_text" android:textSize="22sp" android:textStyle="bold" android:layout_marginBottom="4dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/stat_pending_review" android:textColor="@color/text_dim" android:textSize="11sp" android:textAllCaps="true" android:letterSpacing="0.06"/>
                </LinearLayout>
            </GridLayout>
            <!--  ════ SECTION LABEL ════  -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginBottom="12dp" android:layout_marginTop="4dp" android:text="@string/section_recent_activity" android:textColor="@color/text_dim" android:textSize="12sp" android:textAllCaps="true" android:letterSpacing="0.08"/>
            <!--  ════ ACTIVITY CARD 1 ════  -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="10dp" android:background="@drawable/bg_stat_card" android:orientation="vertical" android:padding="14dp">
                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                    <TextView android:id="@+id/tv_biz_name_1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_centerVertical="true" android:layout_toStartOf="@id/tv_biz_status_1" android:layout_alignParentStart="true" android:text="Awaiting AI check..." android:textColor="@color/text_primary" android:textSize="14sp" android:maxLines="1" android:ellipsize="end"/>
                    <TextView android:id="@+id/tv_biz_status_1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:background="@drawable/bg_tag_amber" android:paddingStart="8dp" android:paddingEnd="8dp" android:paddingTop="4dp" android:paddingBottom="4dp" android:text="FETCHING" android:textColor="@color/tag_amber_text" android:textSize="11sp" android:textStyle="bold"/>
                </RelativeLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="Just now · AI processing" android:textColor="@color/text_dim" android:textSize="12sp"/>
            </LinearLayout>
            <!--  ════ ACTIVITY CARD 2 ════  -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="10dp" android:background="@drawable/bg_stat_card" android:orientation="vertical" android:padding="14dp">
                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                    <TextView android:id="@+id/tv_biz_name_2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_centerVertical="true" android:layout_toStartOf="@id/tv_biz_status_2" android:layout_alignParentStart="true" android:text="Awaiting AI check..." android:textColor="@color/text_primary" android:textSize="14sp" android:maxLines="1" android:ellipsize="end"/>
                    <TextView android:id="@+id/tv_biz_status_2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:background="@drawable/bg_tag_amber" android:paddingStart="8dp" android:paddingEnd="8dp" android:paddingTop="4dp" android:paddingBottom="4dp" android:text="FETCHING" android:textColor="@color/tag_amber_text" android:textSize="11sp" android:textStyle="bold"/>
                </RelativeLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="Just now · AI processing" android:textColor="@color/text_dim" android:textSize="12sp"/>
            </LinearLayout>
            <!--  ════ ACTIVITY CARD 3 ════  -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="10dp" android:background="@drawable/bg_stat_card" android:orientation="vertical" android:padding="14dp">
                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                    <TextView android:id="@+id/tv_biz_name_3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_centerVertical="true" android:layout_toStartOf="@id/tv_biz_status_3" android:layout_alignParentStart="true" android:text="Awaiting AI check..." android:textColor="@color/text_primary" android:textSize="14sp" android:maxLines="1" android:ellipsize="end"/>
                    <TextView android:id="@+id/tv_biz_status_3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:background="@drawable/bg_tag_amber" android:paddingStart="8dp" android:paddingEnd="8dp" android:paddingTop="4dp" android:paddingBottom="4dp" android:text="FETCHING" android:textColor="@color/tag_amber_text" android:textSize="11sp" android:textStyle="bold"/>
                </RelativeLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="Just now · AI processing" android:textColor="@color/text_dim" android:textSize="12sp"/>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
    <!--  ══ 4. BOTTOM NAV — Home tab active ══  -->
    <include android:id="@+id/bottom_nav_layout" layout="@layout/layout_bottom_nav" android:layout_width="match_parent" android:layout_height="64dp"/>
</LinearLayout>