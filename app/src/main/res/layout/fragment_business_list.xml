<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#101E2E">

    <!-- ═══ ACCENT STRIP ═══ -->
    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="@drawable/gradient_accent_strip" />

    <!-- ═══ TOOLBAR ═══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="#0D1926"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="12dp">

        <TextView
            android:id="@+id/tv_toolbar_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="All Businesses"
            android:textColor="#D0E4F5"
            android:textSize="13sp" />

        <ImageView
            android:id="@+id/btn_filter"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/bg_icon_btn"
            android:padding="7dp"
            android:src="@drawable/ic_filter_funnel"
            android:contentDescription="Filter" />

    </LinearLayout>

    <!-- ═══ SEARCH BOX ═══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="38dp"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_search_box"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">

        <ImageView
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_marginEnd="8dp"
            android:src="@drawable/ic_search"
            android:contentDescription="Search icon" />

        <EditText
            android:id="@+id/et_search"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@null"
            android:hint="Search businesses…"
            android:textColorHint="#3A5F80"
            android:textColor="#5A8AAF"
            android:textSize="12sp"
            android:maxLines="1"
            android:imeOptions="actionSearch"
            android:inputType="text" />

    </LinearLayout>

    <!-- ═══ FILTER CHIP ROW ═══ -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="8dp"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/ll_filter_chips"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/chip_all"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_chip_blue_active"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:text="All"
                android:textColor="#4DB8FF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/chip_high_risk"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_chip_red"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:text="High risk"
                android:textColor="#F87171"
                android:textSize="11sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/chip_review"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_chip_amber"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:text="Review"
                android:textColor="#F9A825"
                android:textSize="11sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/chip_matched"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chip_green"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:text="Matched"
                android:textColor="#3FCF8E"
                android:textSize="11sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>
    </HorizontalScrollView>

    <!-- ═══ BUSINESS LIST ═══ -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_business_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="8dp"
        android:clipToPadding="false"
        android:paddingBottom="8dp"
        android:scrollbars="none"
        tools:listitem="@layout/item_business_card" />

    <!-- ═══ EMPTY STATE ═══ -->
    <LinearLayout
        android:id="@+id/ll_empty_state"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No businesses found"
            android:textColor="#8AB0D0"
            android:textSize="14sp"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Try adjusting your filter or search"
            android:textColor="#2E5A82"
            android:textSize="12sp"
            android:gravity="center" />

    </LinearLayout>

    <!-- ═══ BOTTOM NAV — matches your layout_bottom_nav.xml exactly ═══ -->
    <LinearLayout
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:background="#0D1926"
        android:paddingTop="8dp"
        android:gravity="center_vertical">

        <LinearLayout
            android:id="@+id/nav_home"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:id="@+id/iv_nav_home"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_nav_home" />
            <TextView
                android:id="@+id/tv_nav_home"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Home"
                android:textSize="10sp"
                android:textColor="#4D6A85" />
        </LinearLayout>

        <!-- List tab — ACTIVE on this screen -->
        <LinearLayout
            android:id="@+id/nav_list"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:id="@+id/iv_nav_list"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_nav_list_active" />
            <TextView
                android:id="@+id/tv_nav_list"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="List"
                android:textSize="10sp"
                android:textColor="#4DB8FF" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_graph"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:id="@+id/iv_nav_graph"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_nav_graph" />
            <TextView
                android:id="@+id/tv_nav_graph"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Graph"
                android:textSize="10sp"
                android:textColor="#4D6A85" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_search"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:id="@+id/iv_nav_search"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_nav_search" />
            <TextView
                android:id="@+id/tv_nav_search"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Search"
                android:textSize="10sp"
                android:textColor="#4D6A85" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
